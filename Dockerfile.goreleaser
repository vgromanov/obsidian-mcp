# Used by GoReleaser to build release container images. The binary is built on
# the host by GoReleaser and copied in; this image only carries CA roots.
FROM alpine:3.21
RUN apk add --no-cache ca-certificates && adduser -D -u 65532 obsidian
USER obsidian
COPY obsidian-mcp /usr/local/bin/obsidian-mcp
ENTRYPOINT ["/usr/local/bin/obsidian-mcp"]
